TEMPLATE_NAME="ubuntu-24.04-cloud-base"
TEMPLATE_VMID="9002"

IMAGE_PROFILE="configs/images/ubuntu-24.04.env"

PROXMOX_HOST="pve-template-builder"
PROXMOX_REMOTE_DIR="/root/platform-template-builder"

DISK_STORAGE="local-lvm"
CLOUDINIT_STORAGE="local-lvm"
BRIDGE="vmbr0"

CPU_CORES="2"
MEMORY_MB="2048"

BIOS_TYPE="seabios"
MACHINE_TYPE="q35"
DISK_BUS="scsi"
SCSI_CONTROLLER="virtio-scsi-pci"

ENABLE_QEMU_AGENT="true"

FORCE_RECREATE="false"
